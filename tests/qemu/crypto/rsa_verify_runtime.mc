    0xfa, 0x7f, 0xb5, 0x6a, 0xef, 0xd3, 0xdc, 0xc5, 0xff, 0x9c, 0xad, 0x2d,
    0xa2, 0x1a, 0x83, 0xe7, 0x8e, 0xd7, 0x59, 0x36, 0xe3, 0x9f, 0x37, 0x95,
    0xff, 0x71, 0xb8, 0xa9, 0x7e, 0x24, 0xbd, 0x3b, 0x32, 0x41, 0x4a, 0x73,
    0x8d, 0x6b, 0x0a, 0x19, 0xb7, 0x0a, 0x50, 0x5c, 0x18, 0xc3, 0xce, 0x82,
    0x74, 0x50, 0x89, 0xdb, 0x40, 0x45, 0x6c, 0x7a, 0x5a, 0x75, 0xf1, 0x75,
    0xe0, 0xbc, 0x7f, 0xfa,
};
global MSG: [12]u8 = .{ 0x4d, 0x43, 0x20, 0x62, 0x75, 0x6e, 0x64, 0x6c, 0x65, 0x20, 0x76, 0x31 };

export fn rsa_verify_run() -> u32 {
    let m: usize = (&MSG[0]) as usize;
    let np: usize = (&N[0]) as usize;
    let ep: usize = (&E[0]) as usize;

    let ok_valid: bool = rsa_pkcs1_sha256_verify(m, 12, (&SIG[0]) as usize, 256, np, 256, ep, 3);

    SIG[10] = SIG[10] ^ 0x01;
    let ok_tampered: bool = rsa_pkcs1_sha256_verify(m, 12, (&SIG[0]) as usize, 256, np, 256, ep, 3);
    SIG[10] = SIG[10] ^ 0x01;

    let ok_wrongmsg: bool = rsa_pkcs1_sha256_verify(m, 11, (&SIG[0]) as usize, 256, np, 256, ep, 3);

    if ok_valid && !ok_tampered && !ok_wrongmsg { return 1; }
    return 0;
}
