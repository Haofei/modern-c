// Core (host-testable) of the MC RSA-PKCS#1/SHA-256 signature-verify proof over the
// vendored constant-time BearSSL i31 engine (kernel/crypto/rsa_verify.mc). Embeds a real
// RSA-2048 public key (n,e) and a genuine openssl signature of "MC bundle v1"; the entry
// returns 1 iff the valid signature VERIFIES and both a one-bit-tampered signature and a
// wrong message are REJECTED — the accept+reject behavior a signed-bundle loader needs.
// Vector generated with: openssl genrsa 2048 | openssl dgst -sha256 -sign.

import "kernel/crypto/rsa_verify.mc";

global N: [256]u8 = .{
    0xcc, 0xa7, 0x15, 0xae, 0x57, 0xa4, 0x2a, 0x77, 0x98, 0x6a, 0xb5, 0x19,
    0x8d, 0xe6, 0x0c, 0x3b, 0xc5, 0x5c, 0xd2, 0x13, 0xd7, 0x23, 0xd5, 0x30,
