    0x1e, 0x5c, 0x26, 0x14, 0x16, 0x87, 0xd1, 0x29, 0x7a, 0x44, 0x1a, 0xca,
    0xb2, 0xab, 0x02, 0x72, 0x17, 0x70, 0xd4, 0x48, 0x03, 0x55, 0x15, 0x6f,
    0xd1, 0xc4, 0xb6, 0x9c, 0xfb, 0xa1, 0x2b, 0x0f, 0xf6, 0xd3, 0x4f, 0xc6,
    0x26, 0xa4, 0x84, 0x20, 0xad, 0x79, 0x9d, 0x97, 0x11, 0xe5, 0x4e, 0xa6,
    0xbe, 0x9e, 0x9d, 0xc4, 0xc1, 0xc4, 0x00, 0xb8, 0xf1, 0x97, 0xde, 0xc3,
    0x56, 0xc3, 0x7b, 0xf7, 0xf3, 0x30, 0x33, 0x78, 0x95, 0xfa, 0xdc, 0xa2,
    0xef, 0x73, 0xfa, 0x9c, 0x0a, 0x96, 0x44, 0xfb, 0x4c, 0xaa, 0x9b, 0xaf,
    0xed, 0x1e, 0x04, 0x4a, 0x25, 0xcb, 0x7c, 0xc3, 0x0f, 0xad, 0xe5, 0xe6,
    0xca, 0x3b, 0xf6, 0x63, 0xbe, 0x1e, 0xe9, 0x52, 0x7b, 0xa4, 0x46, 0x5d,
    0x9b, 0x2c, 0xfe, 0x7d, 0xab, 0x62, 0xf3, 0x3f, 0x0a, 0xe7, 0xa5, 0x98,
    0x64, 0x49, 0x61, 0x2d, 0xa3, 0xef, 0x7f, 0x53, 0x58, 0xfa, 0x9e, 0x1e,
    0x96, 0xa6, 0x8e, 0x44, 0x38, 0x15, 0x19, 0x41, 0x0c, 0xb0, 0x39, 0x00,
    0x2a, 0xa5, 0xbf, 0x4d, 0x41, 0x2a, 0x57, 0xca, 0x01, 0x21, 0x41, 0x7b,
    0xad, 0x1e, 0xf3, 0x2a, 0x21, 0x2d, 0x16, 0x73, 0x6c, 0x2b, 0xae, 0x1f,
    0xc1, 0xe9, 0x76, 0xb0, 0xaa, 0x39, 0x72, 0x93, 0xcf, 0xc0, 0xc1, 0x29,
    0xbd, 0x28, 0x8b, 0x2d, 0x3b, 0x3a, 0x38, 0xf9, 0x36, 0xe5, 0xc5, 0x05,
    0x9d, 0xe7, 0xc2, 0x8d,
};
global E: [3]u8 = .{ 0x01, 0x00, 0x01 };
global SIG: [256]u8 = .{
    0x14, 0x05, 0xe4, 0xe6, 0x35, 0x47, 0x1b, 0xb4, 0x16, 0xf4, 0x46, 0xe5,
    0x72, 0x93, 0xca, 0x20, 0x27, 0x8d, 0x76, 0xd2, 0x18, 0x14, 0x3b, 0xe4,
    0xd7, 0x03, 0xb7, 0x75, 0xeb, 0x3d, 0xfe, 0x0c, 0xad, 0xdf, 0x57, 0x96,
    0xcb, 0x2a, 0xb4, 0x51, 0xe8, 0x5b, 0x22, 0xa2, 0x73, 0x91, 0x27, 0x4d,
    0xe2, 0x04, 0x73, 0x1d, 0xee, 0xdd, 0x11, 0x23, 0xd2, 0xce, 0x90, 0xe9,
