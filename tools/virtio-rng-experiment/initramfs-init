#!/bin/busybox sh

/bin/busybox --install -s /bin
mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys

fault_matrix=0
pm_matrix=0
transport_matrix=0
register_fault_matrix=0
for argument in $(cat /proc/cmdline); do
	case "$argument" in
	vrng_live_fault_matrix=1) fault_matrix=1 ;;
	vrng_live_pm_matrix=1) pm_matrix=1 ;;
	vrng_live_transport_matrix=1) transport_matrix=1 ;;
	vrng_live_register_fault_matrix=1) register_fault_matrix=1 ;;
	esac
done

exercise_fault()
{
	name=$1
	parameter=$2
	value=$3
	reset_value=$4
	attempt=0

	echo "VRNG-LIVE: injecting $name"
	if ! echo "$value" > "$parameter"; then
		echo "VRNG-LIVE: FAIL setting $name"
		poweroff -f
	fi
	if [ "$(cat "$parameter")" != "$value" ]; then
		echo "VRNG-LIVE: FAIL $name readback"
		poweroff -f
	fi

	# Drive the hwrng buffer until the next driver transition consumes it.
	while [ "$(cat "$parameter")" != "$reset_value" ] &&
		[ "$attempt" -lt 100 ]; do
		dd if=/dev/hwrng of=/dev/null bs=64 count=1 2>/dev/null || true
		attempt=$((attempt + 1))
	done
	if [ "$(cat "$parameter")" != "$reset_value" ]; then
		echo "VRNG-LIVE: FAIL $name was not consumed"
		poweroff -f
	fi

	# Transient completion and queue errors must leave the device usable.
	attempt=0
	while ! dd if=/dev/hwrng of=/dev/null bs=64 count=1 2>/dev/null; do
		attempt=$((attempt + 1))
		if [ "$attempt" -ge 20 ]; then
			echo "VRNG-LIVE: FAIL $name did not recover"
			poweroff -f
		fi
	done
	echo "VRNG-LIVE: $name recovered"
}

wait_for_hwrng()
{
	attempt=0
	while [ ! -c /dev/hwrng ] && [ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	[ -c /dev/hwrng ]
}

check_driver_lifecycle_teardown()
{
	stage_parameter=/sys/module/virtio_rng/parameters/lang_last_driver_stage
	avail_parameter=/sys/module/virtio_rng/parameters/lang_last_driver_avail
	events_parameter=/sys/module/virtio_rng/parameters/lang_last_driver_events
	mismatches_parameter=/sys/module/virtio_rng/parameters/lang_last_driver_mismatches

	# The ordinary non-shadow configuration intentionally has no model.
	if [ ! -r "$stage_parameter" ]; then
		return
	fi
	stage=$(cat "$stage_parameter")
	avail=$(cat "$avail_parameter")
	events=$(cat "$events_parameter")
	mismatches=$(cat "$mismatches_parameter")
	if [ "$stage" != "4" ] || [ "$avail" != "0" ] ||
		[ "$mismatches" != "0" ] || [ "$events" -le 0 ]; then
		echo "VRNG-LIVE: FAIL driver lifecycle teardown stage=$stage avail=$avail events=$events mismatches=$mismatches"
		poweroff -f
	fi
	echo "VRNG-LIVE: driver lifecycle teardown passed events=$events"
}

if [ "$register_fault_matrix" = "1" ]; then
	echo "VRNG-LIVE: checking registration-failure degraded state"
	sleep 0.2
	register_fault_device=""
	for device_path in /sys/bus/virtio/drivers/virtio_rng/virtio*; do
		if [ -e "$device_path" ]; then
			register_fault_device=${device_path##*/}
			break
		fi
	done
	if [ -z "$register_fault_device" ]; then
		echo "VRNG-LIVE: FAIL registration-fault device is not bound"
		poweroff -f
	fi
	if dd if=/dev/hwrng of=/dev/null bs=1 count=1 2>/dev/null; then
		echo "VRNG-LIVE: FAIL failed registration exposed a readable hwrng"
		poweroff -f
	fi
	echo "$register_fault_device" > /sys/bus/virtio/drivers/virtio_rng/unbind
	if [ -L "/sys/bus/virtio/devices/$register_fault_device/driver" ]; then
		echo "VRNG-LIVE: FAIL degraded device remained bound after unbind"
		poweroff -f
	fi
	check_driver_lifecycle_teardown
	echo "VRNG-LIVE: registration-failure degraded state passed"
	poweroff -f
fi

echo "VRNG-LIVE: waiting for /dev/hwrng"
if ! wait_for_hwrng; then
	echo "VRNG-LIVE: FAIL /dev/hwrng was not created"
	poweroff -f
fi

echo "VRNG-LIVE: checking normal reads"
if ! dd if=/dev/hwrng of=/dev/null bs=64 count=100; then
	echo "VRNG-LIVE: FAIL normal read"
	poweroff -f
fi
echo "VRNG-LIVE: normal reads passed"

echo "VRNG-LIVE: checking nonblocking read"
if ! /bin/vrng-nonblock; then
	echo "VRNG-LIVE: FAIL nonblocking read"
	poweroff -f
fi
echo "VRNG-LIVE: nonblocking read passed"

echo "VRNG-LIVE: checking small-block reads"
for block_size in 1 3 7; do
	if ! dd if=/dev/hwrng of=/dev/null bs="$block_size" count=257; then
		echo "VRNG-LIVE: FAIL small-block read bs=$block_size"
		poweroff -f
	fi
done
echo "VRNG-LIVE: small-block reads passed"

chunk_limit_parameter=/sys/module/virtio_rng/parameters/lang_copy_chunk_limit
if [ -w "$chunk_limit_parameter" ]; then
	echo "VRNG-LIVE: checking driver partial-copy path"
	if ! echo 3 > "$chunk_limit_parameter"; then
		echo "VRNG-LIVE: FAIL setting driver copy chunk limit"
		poweroff -f
	fi
	if [ "$(cat "$chunk_limit_parameter")" != "3" ]; then
		echo "VRNG-LIVE: FAIL driver copy chunk limit readback"
		poweroff -f
	fi
	if ! dd if=/dev/hwrng of=/dev/null bs=64 count=32; then
		echo "VRNG-LIVE: FAIL driver partial-copy read"
		poweroff -f
	fi
	if ! echo 0 > "$chunk_limit_parameter"; then
		echo "VRNG-LIVE: FAIL clearing driver copy chunk limit"
		poweroff -f
	fi
	if [ "$(cat "$chunk_limit_parameter")" != "0" ]; then
		echo "VRNG-LIVE: FAIL cleared copy chunk limit readback"
		poweroff -f
	fi
	echo "VRNG-LIVE: driver partial-copy path passed"
fi

if [ "$fault_matrix" = "1" ]; then
	completion_parameter=/sys/module/virtio_rng/parameters/lang_completion_override
	stale_parameter=/sys/module/virtio_rng/parameters/lang_stale_once
	fail_add_parameter=/sys/module/virtio_rng/parameters/lang_fail_add_once

	for parameter in "$completion_parameter" "$stale_parameter" \
		"$fail_add_parameter"; do
		if [ ! -w "$parameter" ]; then
			echo "VRNG-LIVE: FAIL missing fault parameter $parameter"
			poweroff -f
		fi
	done

	exercise_fault "zero completion" "$completion_parameter" 0 -1
	exercise_fault "oversize completion" "$completion_parameter" 4096 -1
	exercise_fault "stale completion" "$stale_parameter" 1 0
	exercise_fault "queue-add failure" "$fail_add_parameter" 1 0
	echo "VRNG-LIVE: fault matrix passed"
fi

if [ "$pm_matrix" = "1" ]; then
	pm_test=/sys/power/pm_test
	pm_state=/sys/power/state
	if [ ! -w "$pm_test" ] || [ ! -w "$pm_state" ]; then
		echo "VRNG-LIVE: FAIL PM test sysfs is unavailable"
		poweroff -f
	fi
	if ! grep -qw mem "$pm_state"; then
		echo "VRNG-LIVE: FAIL suspend-to-RAM state is unavailable"
		poweroff -f
	fi
	if ! echo devices > "$pm_test" || ! grep -q '\[devices\]' "$pm_test"; then
		echo "VRNG-LIVE: FAIL selecting devices PM test level"
		poweroff -f
	fi

	cycle=1
	while [ "$cycle" -le 3 ]; do
		echo "VRNG-LIVE: suspend/restore cycle $cycle"
		if ! echo mem > "$pm_state"; then
			echo "VRNG-LIVE: FAIL suspend/restore cycle $cycle"
			poweroff -f
		fi
		if ! wait_for_hwrng; then
			echo "VRNG-LIVE: FAIL /dev/hwrng missing after cycle $cycle"
			poweroff -f
		fi
		if ! dd if=/dev/hwrng of=/dev/null bs=64 count=32; then
			echo "VRNG-LIVE: FAIL read after suspend/restore cycle $cycle"
			poweroff -f
		fi
		cycle=$((cycle + 1))
	done
	if ! echo none > "$pm_test" || ! grep -q '\[none\]' "$pm_test"; then
		echo "VRNG-LIVE: FAIL clearing PM test level"
		poweroff -f
	fi
	echo "VRNG-LIVE: suspend/restore matrix passed"
fi

if [ "$transport_matrix" = "1" ]; then
	hold_parameter=/sys/module/virtio_rng/parameters/lang_hold_completion
	held_parameter=/sys/module/virtio_rng/parameters/lang_completion_held
	if [ ! -w "$hold_parameter" ] || [ ! -r "$held_parameter" ]; then
		echo "VRNG-LIVE: FAIL transport test requires completion hold controls"
		poweroff -f
	fi
	transport_device=""
	for device_path in /sys/bus/virtio/drivers/virtio_rng/virtio*; do
		if [ -e "$device_path" ]; then
			transport_device=${device_path##*/}
			break
		fi
	done
	if [ -z "$transport_device" ]; then
		echo "VRNG-LIVE: FAIL transport device was not found"
		poweroff -f
	fi

	if ! echo 1 > "$hold_parameter"; then
		echo "VRNG-LIVE: FAIL enabling transport completion hold"
		poweroff -f
	fi
	dd if=/dev/hwrng of=/dev/null bs=64 count=1000000 &
	transport_reader=$!
	attempt=0
	while [ "$(cat "$held_parameter")" != "1" ] &&
		[ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ "$(cat "$held_parameter")" != "1" ]; then
		echo "VRNG-LIVE: FAIL transport completion did not reach held state"
		kill "$transport_reader" 2>/dev/null
		poweroff -f
	fi
	echo "VRNG-LIVE: transport hot-unplug ready"

	attempt=0
	while [ -e "/sys/bus/virtio/devices/$transport_device" ] &&
		[ "$attempt" -lt 200 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ -e "/sys/bus/virtio/devices/$transport_device" ]; then
		echo "VRNG-LIVE: FAIL transport device was not removed"
		kill "$transport_reader" 2>/dev/null
		poweroff -f
	fi
	attempt=0
	while kill -0 "$transport_reader" 2>/dev/null &&
		[ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if kill -0 "$transport_reader" 2>/dev/null; then
		echo "VRNG-LIVE: FAIL transport reader did not terminate"
		kill "$transport_reader" 2>/dev/null
		poweroff -f
	fi
	wait "$transport_reader"
	transport_status=$?
	if ! echo 0 > "$hold_parameter"; then
		echo "VRNG-LIVE: FAIL clearing transport completion hold"
		poweroff -f
	fi
	echo "VRNG-LIVE: transport hot-unplug observed status=$transport_status"

	attempt=0
	while [ "$attempt" -lt 200 ]; do
		for device_path in /sys/bus/virtio/drivers/virtio_rng/virtio*; do
			if [ -e "$device_path" ]; then
				transport_device=${device_path##*/}
				break 2
			fi
		done
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ "$attempt" -ge 200 ]; then
		echo "VRNG-LIVE: FAIL transport device was not re-added"
		poweroff -f
	fi
	if ! wait_for_hwrng ||
		! dd if=/dev/hwrng of=/dev/null bs=64 count=32; then
		echo "VRNG-LIVE: FAIL read after transport re-add"
		poweroff -f
	fi
	echo "VRNG-LIVE: transport hot-unplug/replug passed"
fi

echo "VRNG-LIVE: starting readers for removal race"
hold_parameter=/sys/module/virtio_rng/parameters/lang_hold_completion
held_parameter=/sys/module/virtio_rng/parameters/lang_completion_held
publication_hold_parameter=/sys/module/virtio_rng/parameters/lang_hold_publication
publication_held_parameter=/sys/module/virtio_rng/parameters/lang_publication_held
remove_begun_parameter=/sys/module/virtio_rng/parameters/lang_remove_begun
last_avail_parameter=/sys/module/virtio_rng/parameters/lang_last_remove_data_avail
last_lifecycle_parameter=/sys/module/virtio_rng/parameters/lang_last_remove_lifecycle
last_phase_parameter=/sys/module/virtio_rng/parameters/lang_last_remove_phase
publication_barrier=0
if [ -w "$publication_hold_parameter" ] &&
	[ -r "$publication_held_parameter" ] &&
	[ -r "$remove_begun_parameter" ]; then
	echo 1 > "$publication_hold_parameter"
	publication_barrier=1
elif [ -w "$hold_parameter" ] && [ -r "$held_parameter" ]; then
	echo 1 > "$hold_parameter"
fi
dd if=/dev/hwrng of=/dev/null bs=64 count=1000000 &
reader_one=$!
dd if=/dev/hwrng of=/dev/null bs=127 count=1000000 &
reader_two=$!

if [ "$publication_barrier" = "1" ]; then
	attempt=0
	while [ "$(cat "$publication_held_parameter")" != "1" ] &&
		[ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ "$(cat "$publication_held_parameter")" != "1" ]; then
		echo "VRNG-LIVE: FAIL publication did not reach held state"
		kill "$reader_one" "$reader_two" 2>/dev/null
		poweroff -f
	fi
	echo "VRNG-LIVE: post-core publication synchronization reached"
elif [ -w "$hold_parameter" ] && [ -r "$held_parameter" ]; then
	attempt=0
	while [ "$(cat "$held_parameter")" != "1" ] && [ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ "$(cat "$held_parameter")" != "1" ]; then
		echo "VRNG-LIVE: FAIL completion did not reach held state"
		kill "$reader_one" "$reader_two" 2>/dev/null
		poweroff -f
	fi
	echo "VRNG-LIVE: blocked-reader synchronization reached"
else
	sleep 0.2
fi

(
	for device_path in /sys/bus/virtio/drivers/virtio_rng/virtio*; do
		if [ -e "$device_path" ]; then
			device=${device_path##*/}
			echo "VRNG-LIVE: unbinding $device"
			echo "$device" > /sys/bus/virtio/drivers/virtio_rng/unbind
		fi
	done
) &
unbind_pid=$!

if [ "$publication_barrier" = "1" ]; then
	attempt=0
	while [ "$(cat "$remove_begun_parameter")" != "1" ] &&
		[ "$attempt" -lt 100 ]; do
		sleep 0.05
		attempt=$((attempt + 1))
	done
	if [ "$(cat "$remove_begun_parameter")" != "1" ]; then
		echo "VRNG-LIVE: FAIL removal did not pass begin_remove"
		echo 0 > "$publication_hold_parameter"
		kill "$reader_one" "$reader_two" 2>/dev/null
		poweroff -f
	fi
	echo 0 > "$publication_hold_parameter"
fi

wait "$unbind_pid"
check_driver_lifecycle_teardown

if [ "$publication_barrier" = "1" ]; then
	if [ "$(cat "$last_avail_parameter")" != "0" ] ||
		[ "$(cat "$last_lifecycle_parameter")" != "2" ] ||
		[ "$(cat "$last_phase_parameter")" != "0" ]; then
		echo "VRNG-LIVE: FAIL final removal state avail=$(cat "$last_avail_parameter") lifecycle=$(cat "$last_lifecycle_parameter") phase=$(cat "$last_phase_parameter")"
		poweroff -f
	fi
	echo "VRNG-LIVE: teardown publication ordering passed"
fi

attempt=0
while { kill -0 "$reader_one" 2>/dev/null || kill -0 "$reader_two" 2>/dev/null; } &&
	[ "$attempt" -lt 100 ]; do
	sleep 0.05
	attempt=$((attempt + 1))
done
if kill -0 "$reader_one" 2>/dev/null || kill -0 "$reader_two" 2>/dev/null; then
	echo "VRNG-LIVE: FAIL reader did not terminate after unbind"
	kill "$reader_one" "$reader_two" 2>/dev/null
	poweroff -f
fi
wait "$reader_one"
status_one=$?
wait "$reader_two"
status_two=$?
echo "VRNG-LIVE: removal readers terminated $status_one/$status_two"

echo "VRNG-LIVE: complete"
poweroff -f
