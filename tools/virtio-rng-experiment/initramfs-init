#!/bin/busybox sh

/bin/busybox --install -s /bin
mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys

echo "VRNG-LIVE: waiting for /dev/hwrng"
attempt=0
while [ ! -c /dev/hwrng ] && [ "$attempt" -lt 100 ]; do
	sleep 0.05
	attempt=$((attempt + 1))
done

if [ ! -c /dev/hwrng ]; then
	echo "VRNG-LIVE: FAIL /dev/hwrng was not created"
	poweroff -f
fi

echo "VRNG-LIVE: checking normal reads"
if ! dd if=/dev/hwrng of=/dev/null bs=64 count=100; then
	echo "VRNG-LIVE: FAIL normal read"
	poweroff -f
fi
echo "VRNG-LIVE: normal reads passed"

echo "VRNG-LIVE: starting readers for removal race"
dd if=/dev/hwrng of=/dev/null bs=64 count=1000000 &
reader_one=$!
dd if=/dev/hwrng of=/dev/null bs=127 count=1000000 &
reader_two=$!
sleep 0.2

for device_path in /sys/bus/virtio/drivers/virtio_rng/virtio*; do
	if [ -e "$device_path" ]; then
		device=${device_path##*/}
		echo "VRNG-LIVE: unbinding $device"
		echo "$device" > /sys/bus/virtio/drivers/virtio_rng/unbind
	fi
done

attempt=0
while { kill -0 "$reader_one" 2>/dev/null || kill -0 "$reader_two" 2>/dev/null; } &&
	[ "$attempt" -lt 100 ]; do
	sleep 0.05
	attempt=$((attempt + 1))
done
if kill -0 "$reader_one" 2>/dev/null || kill -0 "$reader_two" 2>/dev/null; then
	echo "VRNG-LIVE: FAIL reader did not terminate after unbind"
	kill "$reader_one" "$reader_two" 2>/dev/null
	poweroff -f
fi
wait "$reader_one"
status_one=$?
wait "$reader_two"
status_two=$?
echo "VRNG-LIVE: removal readers terminated $status_one/$status_two"

echo "VRNG-LIVE: complete"
poweroff -f
